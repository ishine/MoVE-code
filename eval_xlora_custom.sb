#!/bin/bash
# ============================================================
# xLoRA single-sample S2ST inference (Slurm-friendly wrapper)
# ============================================================
#
# Wraps infer_xlora.py.  Uses the trained xLoRA classifier to route between
# emotion experts at inference time -- no LoRA merge step required.
#
# Local:
#   bash eval_xlora_custom.sb \
#     --checkpoint ./outputs/xlora_moe/checkpoint-XXXXX \
#     --model_path ./output/pretrained_hf \
#     --input_audio ./sample.wav \
#     --output_audio ./translated_xlora.wav \
#     --language en
#
# Slurm:
#   sbatch --account=<your_account> --partition=<your_partition> \
#          --gres=gpu:1 eval_xlora_custom.sb [args...]
#
# Optional env vars:
#   CONTAINER_CMD   wrap python in docker/enroot/etc.
# ============================================================

#SBATCH --job-name=kimi-xlora-infer
#SBATCH --output=slurm-%j.out
#SBATCH --error=slurm-%j.err
#SBATCH --nodes=1
#SBATCH --cpus-per-task=4
#SBATCH --gres=gpu:1

set -euo pipefail

cd "$(dirname "$0")"

CHECKPOINT=""
MODEL_PATH=""
INPUT_AUDIO=""
OUTPUT_AUDIO=""
LANGUAGE=""

while [[ "$#" -gt 0 ]]; do
    case "$1" in
        --checkpoint)    CHECKPOINT="$2";    shift 2 ;;
        --model_path)    MODEL_PATH="$2";    shift 2 ;;
        --input_audio)   INPUT_AUDIO="$2";   shift 2 ;;
        --output_audio)  OUTPUT_AUDIO="$2";  shift 2 ;;
        --language)      LANGUAGE="$2";      shift 2 ;;
        -h|--help)       sed -n '2,28p' "$0"; exit 0 ;;
        *) echo "Unknown argument: $1"; exit 1 ;;
    esac
done

: "${CHECKPOINT:?--checkpoint is required (xLoRA training output checkpoint dir)}"
: "${MODEL_PATH:?--model_path is required (base Kimi-Audio model dir)}"
: "${INPUT_AUDIO:?--input_audio is required}"
: "${OUTPUT_AUDIO:?--output_audio is required}"
: "${LANGUAGE:?--language is required (en or zh)}"

CONTAINER_CMD="${CONTAINER_CMD:-}"

${CONTAINER_CMD} python infer_xlora.py \
    --checkpoint_dir "$CHECKPOINT" \
    --model_path "$MODEL_PATH" \
    --input_audio "$INPUT_AUDIO" \
    --output_audio "$OUTPUT_AUDIO" \
    --language "$LANGUAGE"
